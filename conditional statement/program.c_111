#include <stdio.h>

int main()
{
    int p, q, r;

    scanf("%d %d %d", &p, &q, &r);

    if(p == q && q == r)
    {
        printf("Equilateral");
    }
    else if(p == q || q == r || p == r)
    {
        printf("Isosceles");
    }
    else
    {
        printf("Scalene");
    }

    return 0;
}
